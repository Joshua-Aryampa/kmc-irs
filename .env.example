# Copy to .env and adjust values
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (recommended). Start local DB: docker compose up -d db
DATABASE_URL=postgres://irs_user:irs_dev_password@localhost:5432/irs

# Incident report form reference (constant on all PDFs)
INCIDENT_FORM_REFERENCE=KMC.DQHSE.02/26-FM005

# SQLite fallback — comment DATABASE_URL above and uncomment:
# DATABASE_URL=

# --- Keycloak (required for production) ---
# When KEYCLOAK_SERVER_URL is set, login uses SSO only.
# KEYCLOAK_SERVER_URL=https://keycloak.example.com
# KEYCLOAK_REALM=kmc
# KEYCLOAK_CLIENT_ID=irs
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# Admin API credentials for employee search (often same client with service account):
# KEYCLOAK_ADMIN_CLIENT_ID=irs
# KEYCLOAK_ADMIN_CLIENT_SECRET=your-client-secret

# --- Employee signatures (PNG or JPEG) ---
# Base URL where signature images are stored, keyed by Keycloak user ID.
# SIGNATURE_BASE_URL=https://signatures.example.com/employees/
# SIGNATURE_PATH_TEMPLATE={keycloak_id}.png

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=incidents@kiira.local
IRS_BASE_URL=http://127.0.0.1:8000

# Optional Gmail SMTP for dev (see README)
# DEV_EMAIL_INBOX=your@gmail.com
