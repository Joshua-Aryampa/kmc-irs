# Copy to .env and adjust values
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite (default for local dev) — leave DATABASE_URL unset
# PostgreSQL (production / plant server):
# DATABASE_URL=postgres://irs_user:password@localhost:5432/irs

# --- Email (development) ---
# Default: console backend (emails print in the runserver terminal).
#
# To deliver real emails during dev, use Gmail SMTP (free):
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Uncomment and fill in the lines below
# 4. Set DEV_EMAIL_INBOX to the same Gmail address
# 5. Run: python manage.py seed_data
# 6. Test:  python manage.py test_email you@gmail.com
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=your@gmail.com
# DEV_EMAIL_INBOX=your@gmail.com
#
# DEV_EMAIL_INBOX assigns each demo user a unique address via Gmail plus-tagging,
# e.g. your+supervisor-tfa@gmail.com — all arrive in one inbox.

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=incidents@kiira.local
IRS_BASE_URL=http://127.0.0.1:8000
